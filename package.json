{
  "name": "agent-client-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive terminal UI for ACP-compatible agent servers.",
  "scripts": {
    "dev": "$HOME/.bun/bin/bun run src/index.ts",
    "dev:watch": "$HOME/.bun/bin/bun run --watch src/index.ts --demo-transcript",
    "dev:node": "tsx src/index.ts",
    "mock-agent": "$HOME/.bun/bin/bun run src/mock-agent.ts",
    "smoke": "tsx scripts/smoke.ts",
    "trace": "$HOME/.bun/bin/bun run scripts/acp-trace.ts",
    "test": "$HOME/.bun/bin/bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "fuse.js": "^7.4.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
